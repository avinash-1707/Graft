# Copy to ops/.env before `docker compose -f ops/compose.yaml --env-file ops/.env up`.
# These are LOCAL DEV values — never reuse them anywhere real.

# AES-256-GCM master key for tenant AI-provider keys (base64, decodes to 32 bytes).
# The gateway seals with it; ai-/ingestion-service decrypt with it — must match.
#   regenerate: openssl rand -base64 32
AI_KEY_ENCRYPTION_KEY=Z3JhZnQtbG9jYWwtZGV2LWFlczI1Ni1rZXktMzJieXQ=

# Better Auth signing secret (sessions + OTP). Min 32 chars.
#   regenerate: openssl rand -base64 36
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string-min-32-chars

# Public base URL the gateway is reached at (Better Auth issuer + audience). The
# JWT `iss` is baked from this, so it must equal what clients use to reach the
# gateway. Internal services fetch JWKS from http://gateway:8080 regardless.
PUBLIC_GATEWAY_URL=http://localhost:8080

# Browser origins (CORS + Better Auth trusted origins).
WEB_ORIGIN=http://localhost:3000
DASHBOARD_ORIGIN=http://localhost:3001
