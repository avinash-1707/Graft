{
  "uid": "graft-http-red",
  "title": "Graft — HTTP RED",
  "tags": ["graft", "http"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by(job) (rate(graft_http_request_duration_seconds_count[1m]))", "legendFormat": "{{job}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "5xx error rate by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by(job) (rate(graft_http_request_duration_seconds_count{status=~\"5..\"}[1m]))", "legendFormat": "{{job}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 request latency by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by(le, job) (rate(graft_http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{job}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "p50 request latency by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by(le, job) (rate(graft_http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{job}}" }
      ]
    }
  ]
}
