{
  "uid": "graft-realtime",
  "title": "Graft — Realtime",
  "tags": ["graft", "realtime"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active SSE connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(graft_sse_connections_active)" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active WebSocket connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(graft_websocket_connections_active)" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Escalations / min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "decimals": 1 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(graft_conversation_state_transitions_total{to=\"ESCALATION_PENDING\"}[1m])) * 60" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Claims / min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "decimals": 1 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(graft_conversation_state_transitions_total{to=\"AGENT_ASSIGNED\"}[1m])) * 60" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "SSE connections by instance",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by(instance) (graft_sse_connections_active)", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "WebSocket connections by instance",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by(instance) (graft_websocket_connections_active)", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Conversation state transitions by target state",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by(to) (rate(graft_conversation_state_transitions_total[1m]))", "legendFormat": "{{to}}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Claim wins by instance (cross-instance fan-out)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by(instance) (rate(graft_conversation_state_transitions_total{to=\"AGENT_ASSIGNED\"}[5m]))", "legendFormat": "{{instance}}" }
      ]
    }
  ]
}
