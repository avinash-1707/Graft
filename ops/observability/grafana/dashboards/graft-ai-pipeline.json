{
  "uid": "graft-ai-pipeline",
  "title": "Graft — AI Pipeline",
  "tags": ["graft", "ai"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "LLM calls/s by provider + status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by(provider, status) (rate(graft_llm_calls_total[1m]))", "legendFormat": "{{provider}} {{status}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "LLM call p95 latency by provider",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by(le, provider) (rate(graft_llm_call_duration_seconds_bucket[5m])))", "legendFormat": "{{provider}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Queue depth by queue / state",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "max by(queue, state) (graft_queue_depth)", "legendFormat": "{{queue}} {{state}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Escalations by trigger",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by(trigger) (rate(graft_conversation_state_transitions_total{to=\"ESCALATION_PENDING\"}[5m]))", "legendFormat": "{{trigger}}" }
      ]
    }
  ]
}
