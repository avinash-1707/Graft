# Copy to .env before running the backend services on the host:
#   cp .env.example .env
# The backend `start` / `start:worker` scripts load this via Node's
# --env-file-if-exists. Datastores come from `docker compose -f ops/compose.yaml
# up -d` (see ops/README.md). These are LOCAL DEV values — never reuse them.

# --- datastores (host ports from ops/compose.yaml) ---
DATABASE_URL=postgres://graft:graft@localhost:5432/graft
REDIS_URL=redis://localhost:6379

# --- Better Auth (gateway) signing secret; min 32 chars ---
#   regenerate: openssl rand -base64 36
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string-min-32-chars

# --- tenant AI-provider key encryption (gateway seals; ai/ingestion decrypt) ---
# base64, must decode to 32 bytes (AES-256). regenerate: openssl rand -base64 32
AI_KEY_ENCRYPTION_KEY=Z3JhZnQtbG9jYWwtZGV2LWFlczI1Ni1rZXktMzJieXQ=
AI_KEY_ENCRYPTION_KEY_ID=v1

# --- platform AI key (credits mode): orgs without BYOK run AI on this key, metered ---
# Required by ai-service (chat/classifier/query embed) and ingestion-service (KB embed).
PLATFORM_OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# --- billing (Dodo Payments), used by the gateway ---
# Leave the api/webhook keys unset locally to disable checkout + webhooks (read-only
# credit/summary endpoints still work). test_mode for the sandbox.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_ENVIRONMENT=test_mode
# Dodo product ids: subscription products per paid tier + one-time products per top-up pack.
DODO_PRODUCT_PRO=
DODO_PRODUCT_SCALE=
DODO_TOPUP_SMALL=
DODO_TOPUP_MEDIUM=
DODO_TOPUP_LARGE=

# --- object storage: ingestion-service → MinIO (S3-compatible) ---
S3_BUCKET=graft-kb
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# OTEL_EXPORTER_OTLP_ENDPOINT intentionally unset — no local collector. Trace
# exports fail silently; nothing crashes. Set it if you run the obs stack.
