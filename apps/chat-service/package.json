{
  "name": "@graft/chat-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsc -p . --watch --preserveWatchOutput",
    "start": "node --env-file-if-exists=../../.env dist/index.js",
    "check-types": "tsc -p . --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@graft/eslint-config": "workspace:*",
    "@graft/tsconfig": "workspace:*",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@graft/auth": "workspace:*",
    "@graft/db": "workspace:*",
    "@graft/observability": "workspace:*",
    "@graft/shared": "workspace:*",
    "@opentelemetry/instrumentation-fastify": "0.57.0",
    "@opentelemetry/instrumentation-http": "0.218.0",
    "@socket.io/redis-adapter": "8.3.0",
    "fastify": "5.8.5",
    "fastify-plugin": "5.1.0",
    "ioredis": "5.10.1",
    "socket.io": "4.8.3",
    "zod": "4.4.3"
  }
}
