# Gateway base URL the dashboard talks to for auth + org APIs.
NEXT_PUBLIC_API_URL=http://localhost:8080
# Web app (hosts the auth pages); unauthenticated visitors are sent here to sign in.
NEXT_PUBLIC_WEB_URL=http://localhost:3000
# Ingestion-service base URL for knowledge-base upload + document listing.
NEXT_PUBLIC_INGESTION_URL=http://localhost:8082
