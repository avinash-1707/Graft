{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Graft Next.js dashboard",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "resolveJsonModule": true,
    "plugins": [{ "name": "next" }]
  }
}
